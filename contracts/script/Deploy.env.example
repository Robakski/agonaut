# Agonaut Deployment Environment Variables
# Copy to .env and fill in values before deploying

# Private key of the deployer wallet (needs ETH for gas)
DEPLOYER_PRIVATE_KEY=0x...

# Admin address — receives all admin roles. Use a multisig (Gnosis Safe) for mainnet.
# For testnet, can be the deployer address.
ADMIN_ADDRESS=0x...

# Operator address — day-to-day operations (create bounties, manage settings)
# Can be same as admin for testnet.
OPERATOR_ADDRESS=0x...

# Scorer address — the TEE scoring service wallet that submits scores to ScoringOracle
# Generate a dedicated wallet for this. Only this address can submit scores.
SCORER_ADDRESS=0x...

# Guardian address — can trigger emergency pause only (cannot unpause or change state)
# Should be a hot wallet for fast response. Can be same as operator for testnet.
GUARDIAN_ADDRESS=0x...

# Basescan API key for contract verification
# Get one at: https://basescan.org/myapikey
BASESCAN_API_KEY=...
